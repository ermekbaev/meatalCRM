generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  password              String
  name                  String
  role                  UserRole           @default(EMPLOYEE)
  isBlocked             Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  telegramChatId        String?
  phone                 String?
  position              String?
  avatarUrl             String?
  changeLogs            ChangeLog[]
  taskChangeLogs        TaskChangeLog[]
  comments              Comment[]
  offers                CommercialOffer[]  @relation("OfferCreatedBy")
  managedOffers         CommercialOffer[]  @relation("OfferManager")
  invoices              Invoice[]
  requests              Request[]          @relation("AssignedRequests")
  createdRequests       Request[]          @relation("CreatedRequests")
  uploadedFiles         RequestFile[]
  assignedTasks         Task[]             @relation("AssignedTasks")
  createdTasks          Task[]             @relation("CreatedTasks")
  taskComments          TaskComment[]
  uploadedTaskFiles     TaskFile[]
  assignedSubTasks      SubTask[]          @relation("AssignedSubTasks")
  workshops             Workshop[]         @relation("WorkshopMembers")
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  updatedWarehouseItems WarehouseItem[]    @relation("WarehouseUpdatedBy")
  companyId             String?
  company               Client?            @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: SetNull)
  managedClients        Client[]           @relation("ClientManager")
  portalRequests        PortalRequest[]    @relation("PortalRequestCreatedBy")
  portalComments        PortalComment[]
  portalFiles           PortalFile[]
}

model Client {
  id              String            @id @default(cuid())
  type            ClientType        @default(INDIVIDUAL)
  name            String
  phone           String?
  email           String?
  inn             String?
  comment         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  bankAccount     String?
  bankBik         String?
  bankCorAccount  String?
  bankName        String?
  director        String?
  kpp             String?
  legalAddress    String?
  ogrn            String?
  postalAddress   String?
  shortName       String?
  source          String?
  website         String?
  offers          CommercialOffer[]
  invoices        Invoice[]
  requests        Request[]
  tasks           Task[]
  managerId       String?
  manager         User?             @relation("ClientManager", fields: [managerId], references: [id], onDelete: SetNull)
  isPortalEnabled Boolean           @default(false)
  portalUsers     User[]            @relation("CompanyUsers")
  portalRequests        PortalRequest[]
  clientPositions       ClientPosition[]
  clientPositionFolders ClientPositionFolder[]
}

model Request {
  id                 String            @id @default(cuid())
  number             Int               @unique @default(autoincrement())
  title              String
  description        String?
  status             RequestStatus     @default(NEW)
  priority           RequestPriority   @default(MEDIUM)
  amount             Float?
  services           String[]          @default([])
  clientId           String
  assigneeId         String?
  createdById        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  vatIncluded        Boolean           @default(false)
  paymentMethod      String?
  paymentStatus      PaymentStatus     @default(NONE)
  hasMetal           String?
  metalOwner         String?
  laserStatus        String?
  bendingStatus      String?
  weldingStatus      String?
  paintingStatus     String?
  sandblastingStatus String?
  extraWorkStatus    String?
  deliveryStatus     String?
  lockedAt           DateTime?
  changeLogs         ChangeLog[]
  comments           Comment[]
  offers             CommercialOffer[]
  invoices           Invoice[]
  assignee           User?                    @relation("AssignedRequests", fields: [assigneeId], references: [id])
  createdBy          User?                    @relation("CreatedRequests", fields: [createdById], references: [id], onDelete: SetNull)
  client             Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  files              RequestFile[]
  items              RequestItem[]
  subtaskCategories  RequestSubtaskCategory[]
}

model RequestSubtaskCategory {
  id         String           @id @default(cuid())
  requestId  String
  name       String
  order      Int              @default(0)
  archivedAt DateTime?
  createdAt  DateTime         @default(now())
  request    Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  subtasks   RequestSubtask[]

  @@index([requestId])
}

model RequestSubtask {
  id         String                 @id @default(cuid())
  categoryId String
  name       String
  done       Boolean                @default(false)
  order      Int                    @default(0)
  archivedAt DateTime?
  createdAt  DateTime               @default(now())
  category   RequestSubtaskCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model RequestFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  size         Int
  mimeType     String?
  requestId    String
  uploadedById String
  createdAt    DateTime @default(now())
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}

model RequestItem {
  id                 String  @id @default(cuid())
  name               String
  quantity           Float   @default(1)
  unit               String  @default("шт")
  price              Float   @default(0)
  discount           Float   @default(0)
  total              Float   @default(0)
  requestId          String
  isCustomerMaterial Boolean @default(false)
  purchasePrice      Float?
  request            Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  requestId String
  userId    String
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ChangeLog {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  requestId String
  userId    String
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model CommercialOffer {
  id             String      @id @default(cuid())
  number         Int         @unique @default(autoincrement())
  status         OfferStatus @default(DRAFT)
  discount       Float       @default(0)
  total          Float       @default(0)
  notes          String?
  validUntil     DateTime?
  requestId      String?
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  clientId       String?
  numberOverride String?
  vatRate        Float       @default(0)
  managerId      String?
  managerCustom  String?
  deliveryTerms  String?
  client         Client?     @relation(fields: [clientId], references: [id])
  createdBy      User        @relation("OfferCreatedBy", fields: [createdById], references: [id])
  manager        User?       @relation("OfferManager", fields: [managerId], references: [id])
  request        Request?    @relation(fields: [requestId], references: [id])
  items          OfferItem[]
}

model OfferItem {
  id          String          @id @default(cuid())
  service     String
  description String?
  quantity    Float           @default(1)
  unit        String          @default("шт")
  price       Float
  total       Float
  offerId     String
  offer       CommercialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
}

model Task {
  id                 String          @id @default(cuid())
  title              String
  description        String?
  status             String          @default("TODO")
  priority           RequestPriority @default(MEDIUM)
  dueDate            DateTime?
  createdById        String
  clientId           String?
  workshopId         String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  archivedAt         DateTime?
  hasMetal           String?
  metalOwner         String?
  laserStatus        String?
  bendingStatus      String?
  weldingStatus      String?
  paintingStatus     String?
  sandblastingStatus String?
  extraWorkStatus    String?
  deliveryStatus     String?
  checklist          ChecklistItem[]
  subtasks           SubTask[]
  assignees          User[]          @relation("AssignedTasks")
  client             Client?         @relation(fields: [clientId], references: [id])
  createdBy          User            @relation("CreatedTasks", fields: [createdById], references: [id])
  workshop           Workshop?       @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  comments           TaskComment[]
  files              TaskFile[]
  tags               Tag[]           @relation("TagToTask")
  changeLogs         TaskChangeLog[]

  @@index([archivedAt])
}

model TaskChangeLog {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
}

model Workshop {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  isVirtual Boolean  @default(false)
  createdAt DateTime @default(now())
  tasks     Task[]
  members   User[]   @relation("WorkshopMembers")
}

model TaskColumn {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  color     String   @default("#94a3b8")
  order     Int      @default(0)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TaskComment {
  id        String   @id @default(cuid())
  text      String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model TaskFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  size         Int
  mimeType     String?
  taskId       String
  uploadedById String
  createdAt    DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7280")
  tasks Task[] @relation("TagToTask")
}

model ChecklistItem {
  id          String   @id @default(cuid())
  taskId      String
  text        String
  isCompleted Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model SubTask {
  id         String          @id @default(cuid())
  taskId     String
  title      String
  quantity   Float?
  unit       String?
  priority   RequestPriority @default(MEDIUM)
  status     TaskStatus      @default(TODO)
  assigneeId String?
  order      Int             @default(0)
  dueDate    DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  task       Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee   User?           @relation("AssignedSubTasks", fields: [assigneeId], references: [id])
}

model CatalogCategory {
  id        String            @id @default(cuid())
  name      String
  parentId  String?
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  type      String            @default("service")
  parent    CatalogCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children  CatalogCategory[] @relation("SubCategories")
  items     ServiceCatalog[]
}

model ServiceCatalog {
  id              String           @id @default(cuid())
  name            String
  description     String?
  unit            String           @default("шт")
  price           Float?
  category        String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  type            String           @default("service")
  categoryId      String?
  purchasePrice   Float?
  catalogCategory CatalogCategory? @relation(fields: [categoryId], references: [id])
}

model WarehouseItem {
  id          String   @id @default(cuid())
  metalType   String
  steelGrade  String?
  thickness   String?
  size        String?
  unit        String   @default("шт")
  quantity    Float    @default(0)
  note        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("WarehouseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, metalType])
}

model MetalCatalogEntry {
  id         String   @id @default(cuid())
  materialId String
  thickness  Float
  width      Int
  length     Int
  massPerSqM Float
  sheetMass  Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([materialId, thickness, width, length])
}

model BendingCatalogEntry {
  id         String   @id @default(cuid())
  materialId String
  thickness  Float
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([materialId, thickness])
}

model CuttingCatalogEntry {
  id            String   @id @default(cuid())
  materialId    String
  thickness     Float
  minLength     Float
  maxLength     Float?
  pricePerMeter Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanySettings {
  id             String   @id @default("singleton")
  name           String   @default("")
  shortName      String?
  inn            String?
  kpp            String?
  ogrn           String?
  legalAddress   String?
  postalAddress  String?
  phone          String?
  email          String?
  website        String?
  bankName       String?
  bankAccount    String?
  bankCorAccount String?
  bankBik        String?
  director       String?
  updatedAt      DateTime @updatedAt
  accountantName String?
  signatureImage String?
  stampImage     String?
  logoImage      String?
  // Через сколько часов после перевода задачи в DONE она авто-уходит в архив. 0 = не архивировать автоматически.
  taskAutoArchiveHours Int @default(24)
}

model Invoice {
  id             String        @id @default(cuid())
  number         Int           @unique @default(autoincrement())
  date           DateTime      @default(now())
  dueDate        DateTime?
  basis          String?       @default("Основной договор")
  vatRate        Float         @default(0)
  notes          String?
  paymentStatus  PaymentStatus @default(WAITING)
  clientId       String
  requestId      String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  numberOverride String?
  client         Client        @relation(fields: [clientId], references: [id])
  createdBy      User          @relation(fields: [createdById], references: [id])
  request        Request?      @relation(fields: [requestId], references: [id])
  items          InvoiceItem[]
}

model InvoiceItem {
  id        String  @id @default(cuid())
  name      String
  quantity  Float   @default(1)
  unit      String  @default("шт")
  price     Float   @default(0)
  total     Float   @default(0)
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  MANAGER
  FOREMAN
  ENGINEER
  EMPLOYEE
  CONTRACTOR
  CLIENT
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum RequestStatus {
  NEW
  PENDING_APPROVAL
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  NONE
  WAITING
  PAID
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum TaskStatus {
  TODO
  PENDING_APPROVAL
  IN_PROGRESS
  DONE
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  SUBTASK_ASSIGNED
  COMMENT_MENTION
  STATUS_CHANGED
  REQUEST_ASSIGNED
  PORTAL_REQUEST_CREATED
}

enum PortalRequestStatus {
  NEW
  IN_PROGRESS
  READY
}

enum PortalRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Платёжный подстатус — управляется только внутренней ролью (ADMIN/MANAGER),
// клиент видит как read-only бейдж.
enum PortalPaymentStatus {
  NONE      // Без оплаты
  AWAITING  // Ждём оплату
  PAID      // Оплачено
}

// Разделение портальных файлов на чертежи (грузит клиент) и документы
// (грузит менеджер — счета, договоры, акты). Клиент документы только скачивает.
enum PortalFileKind {
  DRAWING
  DOCUMENT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PortalRequest {
  id              String              @id @default(cuid())
  number          Int                 @unique @default(autoincrement())
  companyId       String
  createdByUserId String
  title           String
  description     String?
  status          PortalRequestStatus    @default(NEW)
  priority        PortalRequestPriority  @default(NORMAL)
  paymentStatus   PortalPaymentStatus    @default(NONE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  // Когда заявку впервые открыл внутренний пользователь (ADMIN/MANAGER).
  // Используется для бейджа «новые» в списке компаний и в сайдбаре: пока null —
  // считается непрочитанной, по факту открытия страницы заявки проставляется now().
  firstViewedAt   DateTime?
  // Отметка «отгружено» (ставит менеджер) и «принято» (ставит клиент).
  // null = ещё не отмечено, иначе — момент проставления флага.
  shippedAt       DateTime?
  acceptedAt      DateTime?
  // Производственные подстатусы, которые клиент проставляет сам при создании
  // заявки (какие операции ему нужны). Поля «металл» (hasMetal/metalOwner) сюда
  // сознательно НЕ включены — это внутренняя информация по закупкам.
  laserStatus        String?
  bendingStatus      String?
  weldingStatus      String?
  paintingStatus     String?
  sandblastingStatus String?
  extraWorkStatus    String?
  deliveryStatus     String?
  company         Client              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser   User                @relation("PortalRequestCreatedBy", fields: [createdByUserId], references: [id])
  items           PortalRequestItem[]
  comments        PortalComment[]
  files           PortalFile[]

  @@index([companyId, createdAt])
}

model PortalRequestItem {
  id              String        @id @default(cuid())
  portalRequestId String
  name            String
  quantity        Float         @default(1)
  unit            String        @default("шт")
  price           Float?
  portalRequest   PortalRequest @relation(fields: [portalRequestId], references: [id], onDelete: Cascade)
}

model PortalComment {
  id              String        @id @default(cuid())
  portalRequestId String
  userId          String
  text            String
  createdAt       DateTime      @default(now())
  portalRequest   PortalRequest @relation(fields: [portalRequestId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([portalRequestId, createdAt])
}

model PortalFile {
  id              String          @id @default(cuid())
  portalRequestId String
  filename        String
  originalName    String
  size            Int
  mimeType        String?
  // DRAWING — чертежи клиента (старое поведение, дефолт для совместимости);
  // DOCUMENT — внутренние документы (счета, договоры, акты), грузит менеджер.
  kind            PortalFileKind  @default(DRAWING)
  uploadedById    String
  createdAt       DateTime        @default(now())
  portalRequest   PortalRequest   @relation(fields: [portalRequestId], references: [id], onDelete: Cascade)
  uploadedBy      User            @relation(fields: [uploadedById], references: [id])
}

model ClientPosition {
  id        String                @id @default(cuid())
  companyId String
  folderId  String?
  name      String
  unit      String                @default("шт")
  price     Float?
  createdAt DateTime              @default(now())
  company   Client                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  folder    ClientPositionFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  files     ClientPositionFile[]

  @@index([companyId])
  @@index([folderId])
}

model ClientPositionFile {
  id           String         @id @default(cuid())
  positionId   String
  filename     String
  originalName String
  size         Int            @default(0)
  kind         String         @default("PDF")
  createdAt    DateTime       @default(now())
  position     ClientPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId])
}

model ClientPositionFolder {
  id        String           @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime         @default(now())
  company   Client           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  positions ClientPosition[]

  @@index([companyId])
}
