generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  password          String
  name              String
  role              UserRole          @default(EMPLOYEE)
  isBlocked         Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  telegramChatId    String?
  phone             String?
  changeLogs        ChangeLog[]
  comments          Comment[]
  offers            CommercialOffer[]
  invoices          Invoice[]
  requests          Request[]         @relation("AssignedRequests")
  uploadedFiles     RequestFile[]
  assignedTasks     Task[]            @relation("AssignedTasks")
  createdTasks      Task[]            @relation("CreatedTasks")
  taskComments      TaskComment[]
  uploadedTaskFiles TaskFile[]
}

model Client {
  id             String            @id @default(cuid())
  type           ClientType        @default(INDIVIDUAL)
  name           String
  phone          String?
  email          String?
  inn            String?
  comment        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  bankAccount    String?
  bankBik        String?
  bankCorAccount String?
  bankName       String?
  director       String?
  kpp            String?
  legalAddress   String?
  ogrn           String?
  postalAddress  String?
  shortName      String?
  source         String?
  website        String?
  offers         CommercialOffer[]
  invoices       Invoice[]
  requests       Request[]
  tasks          Task[]
}

model Request {
  id            String            @id @default(cuid())
  number        Int               @unique @default(autoincrement())
  title         String
  description   String?
  status        RequestStatus     @default(NEW)
  priority      RequestPriority   @default(MEDIUM)
  amount        Float?
  services      String[]          @default([])
  clientId      String
  assigneeId    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  vatIncluded   Boolean           @default(false)
  paymentMethod String?
  paymentStatus PaymentStatus     @default(NONE)
  changeLogs    ChangeLog[]
  comments      Comment[]
  offers        CommercialOffer[]
  invoices      Invoice[]
  assignee      User?             @relation("AssignedRequests", fields: [assigneeId], references: [id])
  client        Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  files         RequestFile[]
  items         RequestItem[]
}

model RequestFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  size         Int
  mimeType     String?
  requestId    String
  uploadedById String
  createdAt    DateTime @default(now())
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}

model RequestItem {
  id                 String  @id @default(cuid())
  name               String
  quantity           Float   @default(1)
  unit               String  @default("шт")
  price              Float   @default(0)
  discount           Float   @default(0)
  total              Float   @default(0)
  requestId          String
  isCustomerMaterial Boolean @default(false)
  purchasePrice      Float?
  request            Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  requestId String
  userId    String
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ChangeLog {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  requestId String
  userId    String
  createdAt DateTime @default(now())
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model CommercialOffer {
  id             String      @id @default(cuid())
  number         Int         @unique @default(autoincrement())
  status         OfferStatus @default(DRAFT)
  discount       Float       @default(0)
  total          Float       @default(0)
  notes          String?
  validUntil     DateTime?
  requestId      String?
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  clientId       String?
  numberOverride String?
  vatRate        Float       @default(0)
  client         Client?     @relation(fields: [clientId], references: [id])
  createdBy      User        @relation(fields: [createdById], references: [id])
  request        Request?    @relation(fields: [requestId], references: [id])
  items          OfferItem[]
}

model OfferItem {
  id          String          @id @default(cuid())
  service     String
  description String?
  quantity    Float           @default(1)
  unit        String          @default("шт")
  price       Float
  total       Float
  offerId     String
  offer       CommercialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
}

model Task {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      TaskStatus      @default(TODO)
  priority    RequestPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeId  String?
  createdById String
  clientId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  checklist   ChecklistItem[]
  assignee    User?           @relation("AssignedTasks", fields: [assigneeId], references: [id])
  client      Client?         @relation(fields: [clientId], references: [id])
  createdBy   User            @relation("CreatedTasks", fields: [createdById], references: [id])
  comments    TaskComment[]
  files       TaskFile[]
  tags        Tag[]           @relation("TagToTask")
}

model TaskComment {
  id        String   @id @default(cuid())
  text      String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model TaskFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  size         Int
  mimeType     String?
  taskId       String
  uploadedById String
  createdAt    DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7280")
  tasks Task[] @relation("TagToTask")
}

model ChecklistItem {
  id          String   @id @default(cuid())
  taskId      String
  text        String
  isCompleted Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model CatalogCategory {
  id        String            @id @default(cuid())
  name      String
  parentId  String?
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  type      String            @default("service")
  parent    CatalogCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children  CatalogCategory[] @relation("SubCategories")
  items     ServiceCatalog[]
}

model ServiceCatalog {
  id              String           @id @default(cuid())
  name            String
  description     String?
  unit            String           @default("шт")
  price           Float?
  category        String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  type            String           @default("service")
  categoryId      String?
  purchasePrice   Float?
  catalogCategory CatalogCategory? @relation(fields: [categoryId], references: [id])
}

model MetalCatalogEntry {
  id         String   @id @default(cuid())
  materialId String
  thickness  Float
  width      Int
  length     Int
  massPerSqM Float
  sheetMass  Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([materialId, thickness, width, length])
}

model BendingCatalogEntry {
  id         String   @id @default(cuid())
  materialId String
  thickness  Float
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([materialId, thickness])
}

model CuttingCatalogEntry {
  id            String   @id @default(cuid())
  materialId    String
  thickness     Float
  minLength     Float
  maxLength     Float?
  pricePerMeter Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanySettings {
  id             String   @id @default("singleton")
  name           String   @default("")
  shortName      String?
  inn            String?
  kpp            String?
  ogrn           String?
  legalAddress   String?
  postalAddress  String?
  phone          String?
  email          String?
  website        String?
  bankName       String?
  bankAccount    String?
  bankCorAccount String?
  bankBik        String?
  director       String?
  updatedAt      DateTime @updatedAt
  accountantName String?
  signatureImage String?
  stampImage     String?
}

model Invoice {
  id             String        @id @default(cuid())
  number         Int           @unique @default(autoincrement())
  date           DateTime      @default(now())
  dueDate        DateTime?
  basis          String?       @default("Основной договор")
  vatRate        Float         @default(0)
  notes          String?
  clientId       String
  requestId      String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  numberOverride String?
  client         Client        @relation(fields: [clientId], references: [id])
  createdBy      User          @relation(fields: [createdById], references: [id])
  request        Request?      @relation(fields: [requestId], references: [id])
  items          InvoiceItem[]
}

model InvoiceItem {
  id        String  @id @default(cuid())
  name      String
  quantity  Float   @default(1)
  unit      String  @default("шт")
  price     Float   @default(0)
  total     Float   @default(0)
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  NONE
  WAITING
  PAID
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}
