generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(EMPLOYEE)
  isBlocked      Boolean  @default(false)
  telegramChatId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requests          Request[]       @relation("AssignedRequests")
  comments          Comment[]
  changeLogs        ChangeLog[]
  offers            CommercialOffer[]
  assignedTasks     Task[]          @relation("AssignedTasks")
  createdTasks      Task[]          @relation("CreatedTasks")
  taskComments      TaskComment[]
  uploadedFiles     RequestFile[]
  uploadedTaskFiles TaskFile[]
  invoices          Invoice[]
}

model Client {
  id             String     @id @default(cuid())
  type           ClientType @default(INDIVIDUAL)
  name           String
  shortName      String?
  legalAddress   String?
  postalAddress  String?
  phone          String?
  email          String?
  inn            String?
  kpp            String?
  ogrn           String?
  bankName       String?
  bankAccount    String?
  bankCorAccount String?
  bankBik        String?
  director       String?
  website        String?
  source         String?
  comment        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  requests  Request[]
  tasks     Task[]
  invoices  Invoice[]
}

model Request {
  id          String          @id @default(cuid())
  number      Int             @unique @default(autoincrement())
  title       String
  description String?
  status      RequestStatus   @default(NEW)
  priority    RequestPriority @default(MEDIUM)
  amount      Float?
  vatIncluded    Boolean         @default(false)
  paymentMethod  String?
  services    String[]        @default([])

  clientId   String
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("AssignedRequests", fields: [assigneeId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comments   Comment[]
  changeLogs ChangeLog[]
  offers     CommercialOffer[]
  items      RequestItem[]
  files      RequestFile[]
  invoices   Invoice[]
}

model RequestFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  size         Int
  mimeType     String?
  requestId    String
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

model RequestItem {
  id                 String  @id @default(cuid())
  name               String
  quantity           Float   @default(1)
  unit               String  @default("шт")
  price              Float   @default(0)
  discount           Float   @default(0)
  total              Float   @default(0)
  isCustomerMaterial Boolean @default(false)

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ChangeLog {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model CommercialOffer {
  id          String      @id @default(cuid())
  number      Int         @unique @default(autoincrement())
  status      OfferStatus @default(DRAFT)
  discount    Float       @default(0)
  total       Float       @default(0)
  notes       String?
  validUntil  DateTime?

  requestId   String?
  request     Request? @relation(fields: [requestId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  items     OfferItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OfferItem {
  id          String @id @default(cuid())
  service     String
  description String?
  quantity    Float  @default(1)
  unit        String @default("шт")
  price       Float
  total       Float

  offerId String
  offer   CommercialOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  status      TaskStatus  @default(TODO)
  priority    RequestPriority @default(MEDIUM)
  dueDate     DateTime?

  assigneeId  String?
  assignee    User?   @relation("AssignedTasks", fields: [assigneeId], references: [id])

  createdById String
  createdBy   User    @relation("CreatedTasks", fields: [createdById], references: [id])

  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])

  comments    TaskComment[]
  files       TaskFile[]
  checklist   ChecklistItem[]
  tags        Tag[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskComment {
  id        String   @id @default(cuid())
  text      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model TaskFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  size         Int
  mimeType     String?
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String  @default("#6b7280")
  tasks Task[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text        String
  isCompleted Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model CatalogCategory {
  id       String            @id @default(cuid())
  name     String
  parentId String?
  parent   CatalogCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children CatalogCategory[] @relation("SubCategories")
  items    ServiceCatalog[]
  order    Int               @default(0)
  createdAt DateTime         @default(now())
}

model ServiceCatalog {
  id          String   @id @default(cuid())
  type        String   @default("service")
  name        String
  description String?
  unit        String   @default("шт")
  price       Float?
  category    String?
  categoryId  String?
  catalogCategory CatalogCategory? @relation(fields: [categoryId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model MetalCatalogEntry {
  id         String   @id @default(cuid())
  materialId String
  thickness  Float
  width      Int
  length     Int
  massPerSqM Float
  sheetMass  Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([materialId, thickness, width, length])
}

model BendingCatalogEntry {
  id         String   @id @default(cuid())
  materialId String
  thickness  Float
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([materialId, thickness])
}

model CuttingCatalogEntry {
  id             String   @id @default(cuid())
  materialId     String
  thickness      Float
  minLength      Float
  maxLength      Float?
  pricePerMeter  Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CompanySettings {
  id             String  @id @default("singleton")
  name           String  @default("")
  shortName      String?
  inn            String?
  kpp            String?
  ogrn           String?
  legalAddress   String?
  postalAddress  String?
  phone          String?
  email          String?
  website        String?
  bankName       String?
  bankAccount    String?
  bankCorAccount String?
  bankBik        String?
  director       String?
  accountantName String?
  stampImage     String?
  signatureImage String?
  updatedAt      DateTime @updatedAt
}

model Invoice {
  id          String    @id @default(cuid())
  number      Int       @unique @default(autoincrement())
  date        DateTime  @default(now())
  dueDate     DateTime?
  basis       String?   @default("Основной договор")
  vatRate     Float     @default(0)
  notes       String?

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  requestId   String?
  request     Request? @relation(fields: [requestId], references: [id])

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  items       InvoiceItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvoiceItem {
  id        String  @id @default(cuid())
  name      String
  quantity  Float   @default(1)
  unit      String  @default("шт")
  price     Float   @default(0)
  total     Float   @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}
